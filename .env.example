# Nimbus environment variables.
# Copy this file to .env and fill in your real values. .env is gitignored.

# --- Required: S3-compatible endpoint and credentials ---
# Full endpoint URL for your S3-compatible provider. For Cloudflare R2 this is
# of the form https://<account_id>.r2.cloudflarestorage.com.
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Alternative to R2_ENDPOINT_URL: provide just the account id and nimbus will
# build the R2 endpoint URL for you. Ignored if R2_ENDPOINT_URL is set.
R2_ACCOUNT_ID=your-account-id

R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key

# --- Optional: per-bucket name overrides ---
# By default each NimbusBucketType maps to a bucket named
# `nimbus-{type.value}`: nimbus-raw-data, nimbus-datasets, nimbus-checkpoints,
# nimbus-test. Set any of the following to replace the default with a full
# bucket name of your choice (the value is the full name, not a suffix —
# the "nimbus-" prefix is NOT added).
# NIMBUS_BUCKET_RAW_DATA=my-raw-bucket
# NIMBUS_BUCKET_DATASETS=my-datasets-bucket
# NIMBUS_BUCKET_CHECKPOINTS=my-checkpoints-bucket
# NIMBUS_BUCKET_TEST=my-test-bucket

# --- Optional: integration tests ---
# Set to 1 to enable opt-in tests that hit a real bucket. The suite always
# writes to whichever bucket NimbusBucketType.TEST resolves to (default:
# nimbus-test, or NIMBUS_BUCKET_TEST if set) under the integration-tests
# project namespace.
# NIMBUS_INTEGRATION_TESTS=0
